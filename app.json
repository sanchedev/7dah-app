{
  "expo": {
    "name": "7dah-app",
    "slug": "7dah-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "7dahapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#f9fafb",
          "dark": {
            "backgroundColor": "#030712"
          }
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            {
              "fontFamily": "Rosario",
              "fontDefinitions": [
                {
                  "path": "./assets/fonts/Rosario-Bold.ttf",
                  "weight": 700
                },
                {
                  "path": "./assets/fonts/Rosario-Bold.ttf",
                  "weight": 400
                }
              ]
            }
          ]
        }
      ],
      "expo-image",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4b30d2a7-edb6-4308-983f-e76a9df0877f"
      }
    },
    "owner": "sanchdev"
  }
}
